# Dependencies
node_modules

# Next.js build output
.next
out

# Environment files and secrets
# Every .env variant — real values live ONLY in .env.local locally and in the
# host's (Vercel) environment settings. Never commit any of these.
.env
.env.*
.env*.local
*.env

# Vercel local metadata
.vercel

# Local docs/instructions not required for deployment
AGENTS.md
DESIGN.md
README.md

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor and OS files
.DS_Store
.idea
.vscode
*.swp
.design-references/


# Local-only files / backups
.env.example
context.txt
nested_real_estate_backup.tar

# --- Private keys, certificates & credential files (never commit) ---
*.pem
*.key
*.pfx
*.p12
*.keystore
*.jks
id_rsa
id_rsa.*
id_dsa
id_ed25519
id_ecdsa
# Common service-account / credential JSON dumps
*-service-account.json
service-account*.json
*serviceAccount*.json
*credentials*.json
gha-creds-*.json
secrets.json
.secrets/
auth.json

# --- Supabase CLI local artifacts (keeps schema.sql tracked, ignores local state) ---
.supabase/
supabase/.branches/
supabase/.temp/
supabase/.env
